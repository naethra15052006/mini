{
  "info": {
    "name": "WorkBridge API",
    "description": "Spring Boot Backend API Endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employer@test.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Employer\",\n  \"role\": \"EMPLOYER\",\n  \"skills\": \"\",\n  \"availability\": \"FULL_TIME\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employer@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "USERS",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get All Workers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/workers",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get All Employers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/employers",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"skills\": \"Java, Spring Boot\",\n  \"availability\": \"PART_TIME\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "JOBS",
      "item": [
        {
          "name": "Post a Job (EMPLOYER only)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Web Developer Needed\",\n  \"description\": \"Need a developer for e-commerce website\",\n  \"skill\": \"Web Development\",\n  \"wage\": 500.00,\n  \"maxApplicants\": 5,\n  \"currentApplicants\": 0,\n  \"status\": \"OPEN\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            }
          }
        },
        {
          "name": "Get All Open Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Nearby Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/nearby?latitude=40.7128&longitude=-74.0060",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get My Jobs (EMPLOYER only)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/my-jobs",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Job By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Close Job (EMPLOYER only)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/jobs/1/close",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Delete Job",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/jobs/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "APPLICATIONS",
      "item": [
        {
          "name": "Apply for Job (WORKER only)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/applications/apply/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Applications by Job (EMPLOYER only)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/applications/job/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get My Applications (WORKER only)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/applications/my-applications",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Approve Application (EMPLOYER only)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/applications/1/approve",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Complete Application (WORKER only)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/applications/1/complete",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Reject Application (EMPLOYER only)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/applications/1/reject",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "PAYMENTS",
      "item": [
        {
          "name": "Mark Job as Paid (EMPLOYER only)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/pay/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get My Payments (WORKER only)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/my-payments",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "RATINGS",
      "item": [
        {
          "name": "Give Rating",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/ratings?userId=1&ratingValue=4.5",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Ratings for User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ratings/user/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Get Average Rating",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/ratings/user/1/average",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}

