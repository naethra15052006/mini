          }
        ]
      }
    },
    {
      "name": "Users - Get User by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/1",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Payments - Get My Payments",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/payments/my-payments",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Payments - Mark as Paid",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/payments/pay/1",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Ratings - Give Rating",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/ratings?userId=1&ratingValue=4.5",
          "host": ["{{baseUrl}}"],
          "path": ["ratings"],
          "query": [
            {
              "key": "userId",
              "value": "1"
            },
            {
              "key": "ratingValue",
              "value": "4.5"
            }
          ]
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Ratings - Get User Ratings",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/ratings/user/1",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Ratings - Get Average Rating",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/ratings/user/1/average",
        "header": [
          {
            "key": "Authorization",
