            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Applications - Complete",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/applications/1/complete",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Users - Get All Users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Users - Get Workers",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/workers",
        "header": [
          {
            "key": "Authorization",
