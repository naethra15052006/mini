        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Applications - Get Applications by Job",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/applications/job/1",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Applications - Approve",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/applications/1/approve",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ]
      }
    },
    {
      "name": "Applications - Reject",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/applications/2/reject",
        "header": [
